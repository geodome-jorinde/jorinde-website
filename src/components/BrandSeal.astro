		<path d="m1050.1 898.52c-1.4023 0-2.7852-0.50391-3.9102-1.4297-1.8477-1.5703-2.5938-4.0938-1.8711-6.4219l72.238-233.76-18.023-183.3c-0.28906-3.0469 1.7266-5.832 4.7031-6.5039 3-0.67188 6 1.0078 7.0195 3.8867l53.449 151.25-11.41 4.0312-36.828-104.26 13.262 134.94c0.070312 0.79297 0 1.5977-0.23828 2.3633l-68.387 221.32 83.074-41.965 5.4609 10.789-95.797 48.395c-0.89062 0.44531-1.8164 0.67188-2.7422 0.67188z" />
		<path d="m1104.5 479.06c-0.49219 0-0.99609-0.070312-1.5-0.20312l-97.812-25.199c-2.3984-0.625-4.1875-2.6523-4.4883-5.125l-17.137-139.15c-0.34766-2.7617 1.2344-5.3867 3.8281-6.3828s5.5312-0.097656 7.1172 2.1836l114.96 164.35c1.4414 2.0742 1.4531 4.8359 0.011719 6.9258-1.1523 1.6562-3.0234 2.6016-4.9805 2.6016zm-92.293-36.082 77.965 20.09-91.645-131.03z" />
		<path d="m572.11 512.72-12.07-0.76953 12.336-191.68-218.8 141.68c-1.957 1.2617-4.4648 1.2969-6.4453 0.097656-1.9805-1.2109-3.1094-3.457-2.8672-5.7617l17.531-177.25-175.69 169.09c-2.0273 1.9453-5.1367 2.2422-7.5 0.71875-2.3516-1.5352-3.3477-4.5-2.3867-7.1406l34.105-94.129-87.961 128.84-9.9961-6.8281 114.96-168.38c1.7148-2.5078 5.0391-3.3711 7.7539-1.9805 2.7227 1.3906 3.9844 4.5859 2.9297 7.4531l-41.543 114.68 168.8-162.46c1.8242-1.7539 4.5469-2.1953 6.8281-1.0781 2.2812 1.1055 3.625 3.5156 3.3828 6.0352l-17.93 181.09 218.34-141.39c1.9219-1.2344 4.3672-1.2969 6.3477-0.14453 1.9688 1.1641 3.1211 3.3359 2.9883 5.6055z" />
		<path d="m989.57 314.71c-0.51562 0-1.0195-0.058594-1.5234-0.20313l-174.43-45.371c-2.2188-0.57422-3.9102-2.3398-4.3906-4.5586l-17.148-78.648c-0.51562-2.3984 0.45703-4.8711 2.4727-6.2656 2.0156-1.3906 4.6797-1.4414 6.7305-0.10937l191.58 124.02c2.4961 1.6211 3.4453 4.8008 2.2578 7.5234-0.99219 2.2344-3.1875 3.6133-5.543 3.6133zm-169.32-56.352 134.55 35.004-147.78-95.676z" />
		<path d="m579.18 314.7c-1.5352 0-3.0469-0.58984-4.1875-1.6797-1.4141-1.3555-2.0742-3.3242-1.7891-5.2578l20.172-134.1c0.27734-1.8477 1.3789-3.457 3-4.3672 1.6211-0.91016 3.5625-1.0312 5.2812-0.32422l215.79 88.738c2.4727 1.0195 3.9844 3.5273 3.7188 6.2031-0.26562 2.6641-2.2578 4.8242-4.8711 5.3281l-235.97 45.355c-0.37109 0.082031-0.75781 0.10547-1.1406 0.10547zm24.996-131.63-17.734 118.02 207.64-39.938z" />
