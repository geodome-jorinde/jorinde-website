---
/**
 * Brand seal for GardenGeoDome.
 *
 * Geodesic dome glyph by Methadrone (https://thenounproject.com/creator/Methadrone/)
 * from The Noun Project — "Geodesic Dome" icon #11999, CC BY 3.0.
 * Optional wildflower decoration (BrandFlora) breaks the technical character
 * by adding an organic plant element at the dome's base.
 * Wrapped in optional concentric rings with curved "GARDEN" / "GEODESIC DOME" text.
 *
 * Stroke uses vector-effect="non-scaling-stroke" so lines stay 1.4 screen px
 * at any render size — thin and consistent.
 *
 * variant:
 *   "fine"   — thin double rings (default)
 *   "single" — one thin outer ring
 *   "open"   — no rings, just dome + curved text floating
 *
 * font:
 *   "manrope" (default) — clean geometric sans
 *   "fraunces"          — modern serif with playful "soft" + "wonky" axes
 *   "fraunces-bold"     — Fraunces at heavier weight, more presence
 *   "caveat"            — handwritten, fully playful
 *
 * Color follows currentColor.
 */
import "@fontsource-variable/fraunces";
import "@fontsource/caveat/700.css";
import BrandFlora from "./BrandFlora.astro";

interface Props {
	size?: number;
	variant?: "fine" | "single" | "open";
	font?: "manrope" | "fraunces" | "fraunces-bold" | "caveat";
	flora?: boolean;
}
const { size = 220, variant = "fine", font = "manrope", flora = false } = Astro.props;
const id = Math.random().toString(36).slice(2, 9);
const showOuterRing = variant === "fine" || variant === "single";
const showInnerRing = variant === "fine";

// Font config: family, weight, style, size, letter-spacing for top + bottom text.
const fonts = {
	manrope: {
		family: '"Manrope Variable", "Manrope", system-ui, sans-serif',
		weight: 600,
		style: "normal",
		fvs: "",
		topSize: 80,
		topSpacing: 22,
		botSize: 60,
		botSpacing: 11,
	},
	fraunces: {
		family: '"Fraunces Variable", "Fraunces", Georgia, serif',
		weight: 500,
		style: "normal",
		fvs: '"SOFT" 80, "WONK" 1, "opsz" 144',
		topSize: 84,
		topSpacing: 18,
		botSize: 62,
		botSpacing: 9,
	},
	"fraunces-bold": {
		family: '"Fraunces Variable", "Fraunces", Georgia, serif',
		weight: 700,
		style: "normal",
		fvs: '"SOFT" 100, "WONK" 1, "opsz" 144',
		topSize: 88,
		topSpacing: 16,
		botSize: 66,
		botSpacing: 8,
	},
	caveat: {
		family: '"Caveat", "Bradley Hand", cursive',
		weight: 700,
		style: "normal",
		fvs: "",
		topSize: 110,
		topSpacing: 14,
		botSize: 88,
		botSpacing: 4,
	},
} as const;

const f = fonts[font];
---
<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 1200 1200"
	width={size}
	height={size}
	fill="currentColor"
	stroke="none"
	aria-label="Garden Geodesic Dome"
	role="img"
	class="brandseal-svg"
>
	<defs>
		<!-- Top arc: clockwise (sweep=1), upper half — text reads upright. -->
		<path id={`top-${id}`} d="M 90 600 A 510 510 0 0 1 1110 600" />
		<!-- Bottom arc: counterclockwise (sweep=0), lower half. -->
		<path id={`bot-${id}`} d="M 90 600 A 510 510 0 0 0 1110 600" />
	</defs>

	{showOuterRing && (
		<circle cx="600" cy="600" r="582" fill="none" stroke="currentColor" stroke-width="1.4" vector-effect="non-scaling-stroke" />
	)}
	{showInnerRing && (
		<circle cx="600" cy="600" r="425" fill="none" stroke="currentColor" stroke-width="1.4" vector-effect="non-scaling-stroke" />
	)}

	<!-- Dome glyph (filled silhouette, scaled smaller and re-centered to fit inside r=425 inner ring) -->
	<g transform="translate(263 257) scale(0.6)">
		<path d="m560.03 970.11c-0.28906 0-0.57422-0.011719-0.875-0.058594l-264.18-38.305c-1.9805-0.28906-3.6836-1.5234-4.5703-3.3359-0.875-1.7773-0.80469-3.8867 0.16797-5.6406l122-215.76c1.0781-1.9062 3.0977-3.0859 5.2695-3.0859h0.011719c2.1836 0 4.1992 1.1992 5.2695 3.1094l142.18 254.09c1.1172 2.0039 1.0078 4.4766-0.30078 6.3711-1.1328 1.6562-3.0039 2.6172-4.9727 2.6172zm-254.55-49.07 243.29 35.281-130.93-234.01z" />
