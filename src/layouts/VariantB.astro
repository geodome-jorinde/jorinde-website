---
import BrandSeal from "../components/BrandSeal.astro";
import InstagramIcon from "../components/InstagramIcon.astro";
import "@fontsource-variable/manrope";

interface Props {
	title: string;
	description?: string;
	activeNav?: "workshops" | "projekte" | "mir" | "kontakt" | "buchung" | null;
}
const { title, description = "Geodome Freiburg — Workshops zum Bauen geodätischer Kuppeln in Freiburg.", activeNav = null } = Astro.props;

// All internal links use BASE_URL so deploys at any subpath work; on the custom domain (www.geodome-freiburg.de) BASE_URL is "/".
const root = import.meta.env.BASE_URL.replace(/\/$/, "");
const nav = [
	{ label: "Workshops", href: `${root}/#workshops`, key: "workshops", primary: false },
	{ label: "Projekte", href: `${root}/projekte`, key: "projekte", primary: false },
	{ label: "Über mich", href: `${root}/zu-mir`, key: "mir", primary: false },
	{ label: "Buchen · Fragen", href: `${root}/buchung`, key: "buchung", primary: true },
];
---
<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${root}/favicon.svg`} />
		<style is:global>
			:root {
				--bg: #eef1e6;
				--ink: #1a1a1a;
				--green-deep: #2d4a2b;
				--green: #4f6b47;
				--green-soft: #6e8867;
				--wood: #a88860;
				--line: #1a1a1a;
				--muted: #6b6b6b;
				--surface: #f5f7ee;
			}
			* { box-sizing: border-box; margin: 0; padding: 0; }
			html, body {
				background: var(--bg);
				color: var(--ink);
				font-family: "Manrope Variable", "Manrope", system-ui, sans-serif;
				line-height: 1.5;
				-webkit-font-smoothing: antialiased;
			}
			body {
				max-width: 1400px;
				margin: 0 auto;
			}
			a { color: inherit; text-decoration: none; }
			img { max-width: 100%; display: block; }
			h1, h2, h3, h4 { letter-spacing: -0.02em; line-height: 1.1; font-weight: 300; }
			h1 strong, h2 strong, h3 strong { font-weight: 700; }
			p { color: var(--ink); }

			/* NAV — BrandSeal is the brand mark; no separate wordmark */
			.nav {
				display: flex; justify-content: space-between; align-items: center;
				padding: 1.25rem 3rem;
				border-bottom: 1px solid var(--line);
			}
			.brand {
				color: var(--green-deep);
				display: inline-flex; align-items: center;
				transition: opacity 150ms;
			}
			.brand:hover { opacity: 0.78; }
			.brandseal-svg { display: block; }
			.nav ul { display: flex; gap: 1.75rem; list-style: none; font-size: 0.85rem; font-weight: 500; align-items: center; }
			.nav ul a { transition: color 150ms; padding-bottom: 2px; border-bottom: 1px solid transparent; }
			.nav ul a:hover { color: var(--green-deep); }
			.nav ul a.active { color: var(--green-deep); border-bottom-color: var(--green-deep); }
			.nav ul a.primary {
				background: var(--green-deep);
				color: var(--bg);
				padding: 0.55rem 1.1rem;
				border-bottom: none;
				font-weight: 600;
				transition: background 150ms;
			}
			.nav ul a.primary:hover { background: var(--ink); color: var(--bg); }
			.nav ul a.primary.active { background: var(--ink); color: var(--bg); }

			/* BUTTONS */
			.btn {
				display: inline-block;
				padding: 0.85rem 1.4rem; font-size: 0.9rem; font-weight: 600;
				border: 1px solid var(--ink); background: transparent; color: var(--ink);
				cursor: pointer;
				transition: background 150ms, color 150ms, border-color 150ms;
			}
			.btn:hover { background: var(--ink); color: var(--bg); }
			.btn.primary { background: var(--green-deep); color: var(--bg); border-color: var(--green-deep); }
			.btn.primary:hover { background: var(--ink); border-color: var(--ink); }

			/* TYPOGRAPHIC HELPERS */
			.kicker {
				font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
				color: var(--green-deep); font-weight: 600; margin-bottom: 1.5rem;
				display: inline-flex; align-items: center; gap: 0.5rem;
			}
			.kicker::before { content: ""; width: 22px; height: 1px; background: var(--green-deep); }

			/* FOOTER — dark green with reverse seal + newsletter */
			.foot {
				background: var(--green-deep);
				color: var(--bg);
				padding: 4.5rem 3rem 2rem;
				border-top: none;
			}
			.foot-top {
				display: grid;
				grid-template-columns: auto 1fr;
				gap: 4.5rem;
				align-items: center;
				max-width: 1200px;
				margin: 0 auto 3.5rem;
			}
			.foot-brand-section {
				display: flex; flex-direction: column; align-items: flex-start; gap: 1.25rem;
				color: var(--bg);
			}
			.foot-tagline {
				font-size: 0.85rem;
				color: rgba(238,241,230,0.78);
				letter-spacing: 0.04em;
				max-width: 14em;
				line-height: 1.4;
			}
			.foot-newsletter h3 {
				font-family: "Fraunces Variable", "Fraunces", Georgia, serif;
				font-size: clamp(1.5rem, 2.4vw, 2rem);
				font-weight: 500;
				font-variation-settings: "SOFT" 80, "WONK" 1, "opsz" 144;
				letter-spacing: -0.01em;
				margin-bottom: 0.6rem;
				color: var(--bg);
			}
			.foot-newsletter > p {
				font-size: 0.95rem;
				color: rgba(238,241,230,0.78);
				margin-bottom: 1.5rem;
				max-width: 32em;
				line-height: 1.5;
			}
			.newsletter-form { display: flex; flex-direction: column; gap: 0.85rem; max-width: 36em; }
			.newsletter-row { display: flex; gap: 0.5rem; }
			.newsletter-form input[type="email"] {
				flex: 1;
				background: transparent;
				border: none;
				border-bottom: 1px solid rgba(238,241,230,0.45);
				color: var(--bg);
				padding: 0.6rem 0;
				font: inherit;
				font-size: 0.95rem;
				outline: none;
				transition: border-color 150ms;
			}
			.newsletter-form input[type="email"]:focus { border-bottom-color: var(--bg); }
			.newsletter-form input[type="email"]::placeholder { color: rgba(238,241,230,0.4); }
			.newsletter-form button {
				background: var(--bg);
				color: var(--green-deep);
				border: none;
				padding: 0.65rem 1.5rem;
				font: inherit;
				font-size: 0.88rem;
				font-weight: 600;
				cursor: pointer;
				transition: background 150ms, transform 150ms;
			}
			.newsletter-form button:hover { background: white; }
			.newsletter-consent {
				font-size: 0.78rem;
				color: rgba(238,241,230,0.78);
				line-height: 1.5;
				margin: 0;
				max-width: 38em;
			}
			.newsletter-consent strong { color: var(--bg); font-weight: 600; }
			.newsletter-consent a { color: var(--bg); border-bottom: 1px solid rgba(238,241,230,0.5); }
			.newsletter-consent a:hover { border-bottom-color: var(--bg); }
			.newsletter-success {
				padding: 1rem 1.25rem;
				border: 1px solid rgba(238,241,230,0.35);
				border-radius: 4px;
				max-width: 36em;
			}
			.newsletter-success p {
				font-size: 0.95rem;
				color: rgba(238,241,230,0.92);
				line-height: 1.5;
				margin: 0;
			}
			.newsletter-success strong { color: var(--bg); font-weight: 700; }
			/* Honeypot — visually hidden but accessible to bots that fill all fields */
			.hp-field {
				position: absolute !important;
				left: -10000px !important;
				width: 1px !important;
				height: 1px !important;
				opacity: 0 !important;
				pointer-events: none;
			}

			.foot-bottom {
				border-top: 1px solid rgba(238,241,230,0.18);
				padding-top: 1.5rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.82rem;
				color: rgba(238,241,230,0.6);
				max-width: 1200px;
				margin: 0 auto;
				font-weight: 300;
			}
			.foot-links { display: flex; gap: 2rem; }
			.foot-bottom a { color: rgba(238,241,230,0.6); transition: color 150ms; font-weight: 300; }
			.foot-bottom a:hover { color: var(--bg); }
			.foot-social { display: inline-flex; align-items: center; margin-left: 0.5rem; color: rgba(238,241,230,0.85); }
			.foot-social:hover { color: var(--bg); }

			/* SHARED PAGE-HEADER for inner pages */
			.page-header {
				padding: 5rem 3rem 3rem;
				max-width: 980px;
			}
			.page-header h1 {
				font-size: clamp(2.25rem, 5vw, 4rem);
				font-weight: 300; letter-spacing: -0.035em;
				margin-bottom: 1rem; line-height: 1.05;
			}
			.page-header h1 strong { font-weight: 700; }
			.page-header .lede {
				font-size: 1.15rem; color: var(--muted); max-width: 36em;
				font-weight: 400;
			}

			/* RESPONSIVE BASE */
			@media (max-width: 900px) {
				.foot-top { grid-template-columns: 1fr; gap: 2.5rem; margin-bottom: 2.5rem; }
				.foot-brand-section { align-items: center; text-align: center; }
				.foot-tagline { text-align: center; }
			}
			@media (max-width: 760px) {
				.nav { padding: 0.85rem 1.5rem; flex-wrap: wrap; gap: 1rem; }
				.nav ul { gap: 1rem; flex-wrap: wrap; }
				.foot { padding: 3rem 1.5rem 1.5rem; }
				.foot-bottom { flex-direction: column; gap: 1.25rem; align-items: center; text-align: center; }
				.foot-links { gap: 1.25rem; flex-wrap: wrap; justify-content: center; }
				.newsletter-form { flex-direction: column; align-items: stretch; }
				.newsletter-form button { padding: 0.75rem 1.5rem; }
				.page-header { padding: 3rem 1.5rem 2rem; }
			}
		</style>
	</head>
	<body>
		<nav class="nav">
			<a class="brand" href={`${root}/`} aria-label="Geodome Freiburg — Startseite">
				<BrandSeal size={68} variant="fine" font="fraunces" flora={true} />
			</a>
			<ul>
				{nav.map((n) => {
					const classes = [
						n.primary ? "primary" : null,
						activeNav === n.key ? "active" : null,
					].filter(Boolean).join(" ");
					return <li><a href={n.href} class={classes}>{n.label}</a></li>;
				})}
			</ul>
		</nav>

		<slot />

		<footer class="foot">
			<div class="foot-top">
				<div class="foot-brand-section">
					<div style="color: var(--bg);">
						<BrandSeal size={150} variant="fine" font="fraunces" flora={true} />
					</div>
					<p class="foot-tagline">Workshops für geodätische Kuppeln · Freiburg i.Br.</p>
				</div>
				<div class="foot-newsletter">
					<h3>Bleib in Kontakt.</h3>
					<p>Erfahre als erstes von neuen Workshop-Terminen, Projekten und Wissen rund um den Geodome-Bau.</p>
					<form id="newsletter-form" class="newsletter-form"
						method="POST"
						action="https://c0686c74.sibforms.com/serve/MUIFAP1NVvsyYlIzlwJoK1hgc3fa6gWNFXPTV116Dp7XCVIobLWWn62E4RD4LNLcNeKnZKjKlurblEQKXwwTzrYwHwPx-aP_K7NE_DQFAiS8wnn7lNwl5rKHdOBVkUGPbnFNcQko2No5T3kD8Z_2zHJwxHMJzVF8rwj7xIhPd4CrXw77eUL4LXEQbqQ1_KNI2FnensZ6ZSQxiTFn1w==">
						<input type="text" name="email_address_check" value="" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
						<div class="newsletter-row">
							<input type="email" name="EMAIL" placeholder="deine@email.de" required aria-label="E-Mail-Adresse" autocomplete="email" />
							<button type="submit">Anmelden</button>
						</div>
						<p class="newsletter-consent">
							Mit der Anmeldung stimmst du zu, dass deine E-Mail-Adresse an unseren Newsletter-Anbieter <strong>Brevo</strong> (Sendinblue SAS, Frankreich) zur Verarbeitung übermittelt wird. Du erhältst eine Bestätigungs-E-Mail mit Link zur Anmeldung (Double-Opt-In). Abmelden jederzeit per Link im Newsletter. Mehr in der <a href={`${root}/datenschutz`}>Datenschutzerklärung</a>.
						</p>
						<input type="hidden" name="locale" value="de" />
						<input type="hidden" name="html_type" value="simple" />
					</form>
					<div id="newsletter-success" class="newsletter-success" hidden>
						<p><strong>Danke!</strong> Wir haben dir gerade eine Bestätigungs-E-Mail geschickt — bitte klicke darauf, um die Anmeldung abzuschließen.</p>
					</div>
					<script is:inline>
						(function () {
							const form = document.getElementById("newsletter-form");
							const success = document.getElementById("newsletter-success");
							if (!form || !success) return;
							form.addEventListener("submit", function (e) {
								e.preventDefault();
								// Honeypot: if a bot filled the hidden field, silently bail.
								if (form.email_address_check && form.email_address_check.value) return;
								const email = (form.EMAIL.value || "").trim();
								if (!email) return;
								const fd = new FormData();
								fd.append("EMAIL", email);
								fd.append("locale", "de");
								fd.append("html_type", "simple");
								fetch(form.action, {
									method: "POST",
									body: fd,
									mode: "no-cors",
								}).catch(function () {});
								// Hide the form, show success. We can't read the no-cors
								// response, but Brevo always sends the confirmation email.
								form.hidden = true;
								success.hidden = false;
							});
						})();
					</script>
				</div>
			</div>
			<div class="foot-bottom">
				<div>© 2026 Jorinde Dehmel · Geodome Freiburg</div>
				<div class="foot-links">
					<a href={`${root}/impressum`}>Impressum</a>
					<a href={`${root}/datenschutz`}>Datenschutz</a>
					<a href={`${root}/kontakt`}>Kontakt</a>
					<a class="foot-social" href="https://www.instagram.com/geodome.freiburg" target="_blank" rel="noopener" aria-label="Geodome Freiburg auf Instagram" title="Instagram">
						<InstagramIcon size={20} />
					</a>
				</div>
			</div>
		</footer>
	</body>
</html>
