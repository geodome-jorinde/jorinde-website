---
import VariantB from "../layouts/VariantB.astro";
import BrandSeal from "../components/BrandSeal.astro";
---
<VariantB title="Logo Preview — GardenGeoDome">
	<header class="page-header">
		<div class="kicker">Logo · Iteration 3</div>
		<h1>Schrift-<strong>Varianten.</strong></h1>
		<p class="lede">Innenring auf r=425 verkleinert (war 464), Dome bei scale 0.6 zentriert — viel mehr Platz zwischen den Ringen für größere Schrift. Außenring unverändert. Hier vier Schrift-Optionen, von clean bis verspielt.</p>
	</header>

	<section class="lg-grid">
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={340} variant="fine" font="manrope" /></div>
			<figcaption>
				<strong>A — Manrope (clean sans)</strong>
				<span>Ruhig, modern, geometrisch · matcht Body-Schrift der Site</span>
			</figcaption>
		</figure>
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={340} variant="fine" font="fraunces" /></div>
			<figcaption>
				<strong>B — Fraunces Soft (modern serif)</strong>
				<span>Variabler Serif mit "SOFT 80" + "WONK 1" — leicht verspielt, organische Schwünge</span>
			</figcaption>
		</figure>
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={340} variant="fine" font="fraunces-bold" /></div>
			<figcaption>
				<strong>C — Fraunces Bold (kräftiger Serif)</strong>
				<span>700, "SOFT 100" — mehr Präsenz, Display-Serifen-Charakter</span>
			</figcaption>
		</figure>
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={340} variant="fine" font="caveat" /></div>
			<figcaption>
				<strong>D — Caveat (handgeschrieben)</strong>
				<span>Maximal verspielt, persönlich · wirkt wie skizziert von Hand</span>
			</figcaption>
		</figure>
	</section>

	<section class="lg-row">
		<h2>Größen-Test (Variante B, Fraunces Soft)</h2>
		<div class="lg-sizes" style="color: var(--green-deep)">
			<div><BrandSeal size={400} variant="fine" font="fraunces" /><span>400</span></div>
			<div><BrandSeal size={240} variant="fine" font="fraunces" /><span>240</span></div>
			<div><BrandSeal size={140} variant="fine" font="fraunces" /><span>140</span></div>
			<div><BrandSeal size={80} variant="fine" font="fraunces" /><span>80 (Nav)</span></div>
		</div>
	</section>

	<section class="lg-row dark">
		<h2>Reverse — Marke auf Wald-Grün (alle 4 Schriften)</h2>
		<div class="lg-sizes-dark">
			<div style="color: var(--bg)"><BrandSeal size={200} variant="fine" font="manrope" /><span>Manrope</span></div>
			<div style="color: var(--bg)"><BrandSeal size={200} variant="fine" font="fraunces" /><span>Fraunces Soft</span></div>
			<div style="color: var(--bg)"><BrandSeal size={200} variant="fine" font="fraunces-bold" /><span>Fraunces Bold</span></div>
			<div style="color: var(--bg)"><BrandSeal size={200} variant="fine" font="caveat" /><span>Caveat</span></div>
		</div>
	</section>

	<style>
		.lg-grid {
			padding: 3rem 3rem 2rem;
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
			gap: 3rem 2rem;
			border-top: 1px solid var(--line);
		}
		.lg-grid figure {
			display: flex; flex-direction: column; align-items: center; gap: 1rem;
		}
		.lg-frame {
			width: 100%; min-height: 420px;
			display: flex; align-items: center; justify-content: center;
			padding: 2rem;
			border: 1px solid var(--line);
		}
		.lg-grid figcaption {
			display: flex; flex-direction: column; gap: 0.25rem;
			font-size: 0.9rem; color: var(--muted);
			text-align: center; max-width: 32em;
		}
		.lg-grid figcaption strong { color: var(--ink); font-weight: 700; letter-spacing: 0.04em; }

		.lg-row {
			padding: 4rem 3rem;
			border-top: 1px solid var(--line);
		}
		.lg-row h2 {
			font-size: 1.4rem; font-weight: 300; margin-bottom: 2rem;
		}
		.lg-sizes {
			display: flex; flex-wrap: wrap; gap: 3rem; align-items: flex-end;
		}
		.lg-sizes > div { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
		.lg-sizes span { font-size: 0.78rem; color: var(--muted); letter-spacing: 0.1em; }

		.lg-row.dark { background: var(--green-deep); }
		.lg-row.dark h2 { color: var(--bg); }
		.lg-sizes-dark {
			display: flex; flex-wrap: wrap; gap: 3rem; align-items: center;
		}
		.lg-sizes-dark > div { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
		.lg-sizes-dark span { font-size: 0.78rem; color: var(--bg); opacity: 0.78; letter-spacing: 0.1em; }

		@media (max-width: 760px) {
			.lg-grid, .lg-row { padding: 2rem 1.5rem; }
			.lg-sizes, .lg-sizes-dark { gap: 2rem; }
		}
	</style>
</VariantB>
