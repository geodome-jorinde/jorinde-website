---
import VariantB from "../layouts/VariantB.astro";
import BrandSeal from "../components/BrandSeal.astro";
---
<VariantB title="Logo Preview — GardenGeoDome">
	<header class="page-header">
		<div class="kicker">Logo · Auswahl</div>
		<h1>Schrift- und <strong>Wildblumen-Varianten.</strong></h1>
		<p class="lede">Jorinde, hier zum Aussuchen: alle Schriften jeweils mit und ohne Wildblumen-Akzent. Direktvergleich, Größentest und Reverse-Versionen weiter unten.</p>
	</header>

	<section class="lg-section">
		<h2>Mit Wildblumen</h2>
		<div class="lg-grid">
			<figure>
				<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={320} variant="fine" font="manrope" flora={true} /></div>
				<figcaption><strong>A1 — Manrope</strong><span>Clean sans + organisches Pflanzen-Element</span></figcaption>
			</figure>
			<figure>
				<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={320} variant="fine" font="fraunces" flora={true} /></div>
				<figcaption><strong>A2 — Fraunces Soft</strong><span>Spielerischer Serif trifft Wildblumen-Skizze</span></figcaption>
			</figure>
			<figure>
				<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={320} variant="fine" font="fraunces-bold" flora={true} /></div>
				<figcaption><strong>A3 — Fraunces Bold</strong><span>Mehr Display-Präsenz</span></figcaption>
			</figure>
			<figure>
				<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={320} variant="fine" font="caveat" flora={true} /></div>
				<figcaption><strong>A4 — Caveat</strong><span>Maximal organisch — Handschrift + Pflanze</span></figcaption>
			</figure>
		</div>
	</section>

	<section class="lg-section">
		<h2>Ohne Wildblumen — pur</h2>
		<div class="lg-grid">
			<figure>
				<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={320} variant="fine" font="manrope" flora={false} /></div>
				<figcaption><strong>B1 — Manrope</strong><span>Schlicht, geometrisch, neutral</span></figcaption>
			</figure>
			<figure>
				<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={320} variant="fine" font="fraunces" flora={false} /></div>
				<figcaption><strong>B2 — Fraunces Soft</strong><span>Eleganter Serif, ruhiger Charakter</span></figcaption>
			</figure>
			<figure>
				<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={320} variant="fine" font="fraunces-bold" flora={false} /></div>
				<figcaption><strong>B3 — Fraunces Bold</strong><span>Kräftig, klassisches Display-Serif</span></figcaption>
			</figure>
			<figure>
				<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={320} variant="fine" font="caveat" flora={false} /></div>
				<figcaption><strong>B4 — Caveat</strong><span>Handschrift, persönlich</span></figcaption>
			</figure>
		</div>
	</section>

	<section class="lg-row">
		<h2>Direktvergleich · Fraunces Soft, mit / ohne Wildblumen</h2>
		<div class="lg-sizes" style="color: var(--green-deep)">
			<div><BrandSeal size={300} variant="fine" font="fraunces" flora={false} /><span>Pur</span></div>
			<div><BrandSeal size={300} variant="fine" font="fraunces" flora={true} /><span>Mit Wildblumen</span></div>
		</div>
	</section>

	<section class="lg-row">
		<h2>Größen-Test · Fraunces Soft</h2>
		<p class="lg-sub">Wie sieht der Seal in Nav-Größe aus?</p>
		<div class="lg-sizes" style="color: var(--green-deep)">
			<div><BrandSeal size={400} variant="fine" font="fraunces" flora={true} /><span>400 · mit</span></div>
			<div><BrandSeal size={240} variant="fine" font="fraunces" flora={true} /><span>240 · mit</span></div>
			<div><BrandSeal size={140} variant="fine" font="fraunces" flora={true} /><span>140 · mit</span></div>
			<div><BrandSeal size={68} variant="fine" font="fraunces" flora={true} /><span>68 · Nav</span></div>
		</div>
		<div class="lg-sizes" style="color: var(--green-deep); margin-top: 2rem;">
			<div><BrandSeal size={400} variant="fine" font="fraunces" flora={false} /><span>400 · ohne</span></div>
			<div><BrandSeal size={240} variant="fine" font="fraunces" flora={false} /><span>240 · ohne</span></div>
			<div><BrandSeal size={140} variant="fine" font="fraunces" flora={false} /><span>140 · ohne</span></div>
			<div><BrandSeal size={68} variant="fine" font="fraunces" flora={false} /><span>68 · Nav</span></div>
		</div>
	</section>

	<section class="lg-row dark">
		<h2>Reverse · auf Wald-Grün</h2>
		<p class="lg-sub" style="color: rgba(238,241,230,0.7);">So sieht's im Footer aus.</p>
		<div class="lg-sizes-dark">
			<div style="color: var(--bg)"><BrandSeal size={220} variant="fine" font="fraunces" flora={true} /><span>Mit Wildblumen</span></div>
			<div style="color: var(--bg)"><BrandSeal size={220} variant="fine" font="fraunces" flora={false} /><span>Pur</span></div>
		</div>
	</section>

	<style>
		.lg-section {
			padding: 3rem 3rem 1rem;
			border-top: 1px solid var(--line);
		}
		.lg-section h2 {
			font-family: "Fraunces Variable", "Fraunces", Georgia, serif;
			font-size: clamp(1.5rem, 2.4vw, 2rem);
			font-weight: 500;
			font-variation-settings: "SOFT" 80, "WONK" 1, "opsz" 144;
			margin-bottom: 2rem;
		}
		.lg-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
			gap: 3rem 2rem;
			margin-bottom: 2rem;
		}
		.lg-grid figure {
			display: flex; flex-direction: column; align-items: center; gap: 1rem;
		}
		.lg-frame {
			width: 100%; min-height: 400px;
			display: flex; align-items: center; justify-content: center;
			padding: 2rem;
			border: 1px solid var(--line);
		}
		.lg-grid figcaption {
			display: flex; flex-direction: column; gap: 0.25rem;
			font-size: 0.9rem; color: var(--muted);
			text-align: center; max-width: 32em;
		}
		.lg-grid figcaption strong { color: var(--ink); font-weight: 700; letter-spacing: 0.04em; }

		.lg-row { padding: 4rem 3rem; border-top: 1px solid var(--line); }
		.lg-row h2 {
			font-family: "Fraunces Variable", "Fraunces", Georgia, serif;
			font-size: clamp(1.5rem, 2.4vw, 2rem);
			font-weight: 500;
			font-variation-settings: "SOFT" 80, "WONK" 1, "opsz" 144;
			margin-bottom: 0.5rem;
		}
		.lg-sub { color: var(--muted); margin-bottom: 2rem; font-size: 0.95rem; }
		.lg-sizes { display: flex; flex-wrap: wrap; gap: 3rem; align-items: flex-end; }
		.lg-sizes > div { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
		.lg-sizes span { font-size: 0.78rem; color: var(--muted); letter-spacing: 0.1em; }

		.lg-row.dark { background: var(--green-deep); }
		.lg-row.dark h2 { color: var(--bg); }
		.lg-sizes-dark { display: flex; flex-wrap: wrap; gap: 3rem; align-items: center; }
		.lg-sizes-dark > div { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
		.lg-sizes-dark span { font-size: 0.78rem; color: var(--bg); opacity: 0.78; letter-spacing: 0.1em; }

		@media (max-width: 760px) {
			.lg-section, .lg-row { padding: 2rem 1.5rem; }
			.lg-sizes, .lg-sizes-dark { gap: 2rem; }
		}
	</style>
</VariantB>
