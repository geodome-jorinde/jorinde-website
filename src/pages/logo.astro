---
import VariantB from "../layouts/VariantB.astro";
import BrandSeal from "../components/BrandSeal.astro";
---
<VariantB title="Logo Preview — GardenGeoDome">
	<header class="page-header">
		<div class="kicker">Logo · Iteration 4</div>
		<h1>Brand-Seal mit <strong>Wildblumen.</strong></h1>
		<p class="lede">Color-Blob aus dem Wildblumen-SVG entfernt — nur die organischen Pflanzen-Pfade übernommen, in <code>currentColor</code>. Sitzt am Dome-Fuß und bricht die geometrische Strenge auf. Hier alle Schrift-Varianten mit und ohne Wildblumen.</p>
	</header>

	<section class="lg-grid">
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={340} variant="fine" font="manrope" flora={true} /></div>
			<figcaption>
				<strong>Manrope + Wildblumen</strong>
				<span>Clean sans + organisches Pflanzen-Element</span>
			</figcaption>
		</figure>
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={340} variant="fine" font="fraunces" flora={true} /></div>
			<figcaption>
				<strong>Fraunces Soft + Wildblumen</strong>
				<span>Spielerischer Serif trifft Wildblumen-Skizze</span>
			</figcaption>
		</figure>
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={340} variant="fine" font="fraunces-bold" flora={true} /></div>
			<figcaption>
				<strong>Fraunces Bold + Wildblumen</strong>
				<span>Mehr Display-Präsenz</span>
			</figcaption>
		</figure>
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={340} variant="fine" font="caveat" flora={true} /></div>
			<figcaption>
				<strong>Caveat + Wildblumen</strong>
				<span>Maximal organisch — Handschrift + Pflanze</span>
			</figcaption>
		</figure>
	</section>

	<section class="lg-row">
		<h2>Direktvergleich (Fraunces Soft, mit / ohne Wildblumen)</h2>
		<div class="lg-sizes" style="color: var(--green-deep)">
			<div><BrandSeal size={300} variant="fine" font="fraunces" flora={false} /><span>Ohne</span></div>
			<div><BrandSeal size={300} variant="fine" font="fraunces" flora={true} /><span>Mit Wildblumen</span></div>
		</div>
	</section>

	<section class="lg-row">
		<h2>Größen-Test (Fraunces + Wildblumen)</h2>
		<div class="lg-sizes" style="color: var(--green-deep)">
			<div><BrandSeal size={400} variant="fine" font="fraunces" flora={true} /><span>400</span></div>
			<div><BrandSeal size={240} variant="fine" font="fraunces" flora={true} /><span>240</span></div>
			<div><BrandSeal size={140} variant="fine" font="fraunces" flora={true} /><span>140</span></div>
		</div>
	</section>

	<section class="lg-row dark">
		<h2>Reverse — Marke auf Wald-Grün (mit Wildblumen)</h2>
		<div class="lg-sizes-dark">
			<div style="color: var(--bg)"><BrandSeal size={220} variant="fine" font="fraunces" flora={true} /><span>Fraunces Soft</span></div>
			<div style="color: var(--bg)"><BrandSeal size={220} variant="single" font="fraunces" flora={true} /><span>Single Ring</span></div>
			<div style="color: var(--bg)"><BrandSeal size={220} variant="open" font="fraunces" flora={true} /><span>Ohne Ringe</span></div>
		</div>
	</section>

	<style>
		code {
			font-family: ui-monospace, "SF Mono", Menlo, monospace;
			font-size: 0.9em;
			background: rgba(45,74,43,0.08);
			padding: 0.05em 0.4em;
			border-radius: 2px;
		}
		.lg-grid {
			padding: 3rem 3rem 2rem;
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
			gap: 3rem 2rem;
			border-top: 1px solid var(--line);
		}
		.lg-grid figure { display: flex; flex-direction: column; align-items: center; gap: 1rem; }
		.lg-frame {
			width: 100%; min-height: 420px;
			display: flex; align-items: center; justify-content: center;
			padding: 2rem;
			border: 1px solid var(--line);
		}
		.lg-grid figcaption {
			display: flex; flex-direction: column; gap: 0.25rem;
			font-size: 0.9rem; color: var(--muted);
			text-align: center; max-width: 32em;
		}
		.lg-grid figcaption strong { color: var(--ink); font-weight: 700; letter-spacing: 0.04em; }

		.lg-row { padding: 4rem 3rem; border-top: 1px solid var(--line); }
		.lg-row h2 { font-size: 1.4rem; font-weight: 300; margin-bottom: 2rem; }
		.lg-sizes { display: flex; flex-wrap: wrap; gap: 3rem; align-items: flex-end; }
		.lg-sizes > div { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
		.lg-sizes span { font-size: 0.78rem; color: var(--muted); letter-spacing: 0.1em; }

		.lg-row.dark { background: var(--green-deep); }
		.lg-row.dark h2 { color: var(--bg); }
		.lg-sizes-dark { display: flex; flex-wrap: wrap; gap: 3rem; align-items: center; }
		.lg-sizes-dark > div { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
		.lg-sizes-dark span { font-size: 0.78rem; color: var(--bg); opacity: 0.78; letter-spacing: 0.1em; }

		@media (max-width: 760px) {
			.lg-grid, .lg-row { padding: 2rem 1.5rem; }
			.lg-sizes, .lg-sizes-dark { gap: 2rem; }
		}
	</style>
</VariantB>
