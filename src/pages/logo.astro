---
import VariantB from "../layouts/VariantB.astro";
import BrandSeal from "../components/BrandSeal.astro";
---
<VariantB title="Logo Preview — GardenGeoDome">
	<header class="page-header">
		<div class="kicker">Logo · Iteration 2</div>
		<h1>Brand <strong>Seal.</strong></h1>
		<p class="lede">Drei Varianten — feine Doppellinie, einzelne Außenlinie, gar keine Linien. Linien nutzen <code>vector-effect:non-scaling-stroke</code>, bleiben also bei jeder Größe gleich dünn.</p>
	</header>

	<section class="lg-grid">
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={300} variant="fine" /></div>
			<figcaption>
				<strong>1 — Fine</strong>
				<span>Zwei dünne konzentrische Ringe, mehr Luft zur Schrift</span>
			</figcaption>
		</figure>
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={300} variant="single" /></div>
			<figcaption>
				<strong>2 — Single</strong>
				<span>Nur ein dünner Außenring, innerer weg</span>
			</figcaption>
		</figure>
		<figure>
			<div class="lg-frame" style="color: var(--green-deep)"><BrandSeal size={300} variant="open" /></div>
			<figcaption>
				<strong>3 — Open</strong>
				<span>Keine Ringe, nur Dome + gebogene Schrift im Raum</span>
			</figcaption>
		</figure>
	</section>

	<section class="lg-row">
		<h2>Größen-Test (Variante 1, Fine)</h2>
		<div class="lg-sizes" style="color: var(--green-deep)">
			<div><BrandSeal size={400} variant="fine" /><span>400</span></div>
			<div><BrandSeal size={240} variant="fine" /><span>240</span></div>
			<div><BrandSeal size={140} variant="fine" /><span>140</span></div>
			<div><BrandSeal size={80} variant="fine" /><span>80 (Nav-Größe)</span></div>
		</div>
	</section>

	<section class="lg-row dark">
		<h2>Reverse — Marke auf Wald-Grün</h2>
		<div class="lg-sizes-dark">
			<div style="color: var(--bg)"><BrandSeal size={240} variant="single" /><span>Single, reverse</span></div>
			<div style="color: var(--bg)"><BrandSeal size={240} variant="open" /><span>Open, reverse</span></div>
		</div>
	</section>

	<style>
		code {
			font-family: ui-monospace, "SF Mono", Menlo, monospace;
			font-size: 0.9em;
			background: rgba(45,74,43,0.08);
			padding: 0.05em 0.4em;
			border-radius: 2px;
		}

		.lg-grid {
			padding: 3rem 3rem 2rem;
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
			gap: 3rem 2rem;
			border-top: 1px solid var(--line);
		}
		.lg-grid figure {
			display: flex; flex-direction: column; align-items: center; gap: 1rem;
		}
		.lg-frame {
			width: 100%; min-height: 380px;
			display: flex; align-items: center; justify-content: center;
			padding: 2rem;
			border: 1px solid var(--line);
		}
		.lg-grid figcaption {
			display: flex; flex-direction: column; gap: 0.25rem;
			font-size: 0.9rem; color: var(--muted);
			text-align: center;
		}
		.lg-grid figcaption strong { color: var(--ink); font-weight: 700; letter-spacing: 0.04em; }

		.lg-row {
			padding: 4rem 3rem;
			border-top: 1px solid var(--line);
		}
		.lg-row h2 {
			font-size: 1.4rem; font-weight: 300; margin-bottom: 2rem;
		}
		.lg-sizes {
			display: flex; flex-wrap: wrap; gap: 3rem; align-items: flex-end;
		}
		.lg-sizes > div { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
		.lg-sizes span { font-size: 0.78rem; color: var(--muted); letter-spacing: 0.1em; }

		.lg-row.dark { background: var(--green-deep); }
		.lg-row.dark h2 { color: var(--bg); }
		.lg-sizes-dark {
			display: flex; flex-wrap: wrap; gap: 4rem; align-items: center;
		}
		.lg-sizes-dark > div { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
		.lg-sizes-dark span { font-size: 0.78rem; color: var(--bg); opacity: 0.75; letter-spacing: 0.1em; }

		@media (max-width: 760px) {
			.lg-grid, .lg-row { padding: 2rem 1.5rem; }
			.lg-sizes, .lg-sizes-dark { gap: 2rem; }
		}
	</style>
</VariantB>
