		year: "2025",
		context: "Mit Jugendlichen der Gruppe »Wühlmäuse« — NABU Seeheim-Jugenheim.",
		cover: "51.webp",
		gallery: [],
	},
	{
		slug: "wichteldome",
		title: "Wichteldome",
		year: "2025",
		context: "Weihnachten im Stadtteil Vauban, Freiburg.",
		cover: "46.webp",
		gallery: ["47.webp", "48.webp", "49.webp", "50.webp"],
	},
	{
		slug: "lebensdome",
		title: "Lebensdome",
		year: "2024",
		context: "Im LebensART-Zentrum in Dottingen.",
		cover: "45.webp",
		gallery: ["45a.webp", "45b.webp", "45c.webp"],
	},
	{
		slug: "werkstattdome",
		title: "Werkstattdome",
		year: "2024",
		context: "Workshop mit der offenen Werkstatt FREILab Freiburg e.V.",
		cover: "43.webp",
		gallery: ["44.webp"],
	},
	{
		slug: "gaertnerinnendome",
		title: "Gärtner*Innendome",
		year: "2024",
		context: "Mit dem Verein Weltacker e.V., Freiburg.",
		cover: "39.webp",
		gallery: ["40.webp", "41.webp", "42.webp"],
	},
	{
		slug: "international-domes",
		title: "International Domes",
		year: "2024",
		context: "Auf dem internationalen Kunst- und Kulturfestival, Freiburg.",
		cover: "37.webp",
		gallery: ["38.webp"],
	},
	{
		slug: "bergfritzendome",
