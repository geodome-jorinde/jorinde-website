---
import VariantB from "../layouts/VariantB.astro";
const root = import.meta.env.BASE_URL.replace(/\/$/, "");

// Reverse-chronological — newest first.
// Each project: cover photo + overlaid title; click to expand for the rest.
const projekte = [
	{
		slug: "klimadome",
		title: "Klimadome",
		year: "2025",
		context: "Beim Klimacamp mit den »Students For Future« auf dem Platz der alten Synagoge, Freiburg.",
		cover: "52.jpeg",
		gallery: ["53.jpeg", "54.jpeg"],
	},
	{
		slug: "maeusedome",
		title: "Mäusedome",
		year: "2025",
		context: "Mit Jugendlichen der Gruppe »Wühlmäuse« — NABU Seeheim-Jugenheim.",
		cover: "51.jpeg",
		gallery: [],
	},
	{
		slug: "wichteldome",
		title: "Wichteldome",
		year: "2025",
		context: "Weihnachten im Stadtteil Vauban, Freiburg.",
		cover: "46.jpeg",
		gallery: ["47.jpeg", "48.jpeg", "49.jpeg", "50.jpeg"],
	},
	{
		slug: "lebensdome",
		title: "Lebensdome",
		year: "2024",
		context: "Im LebensART-Zentrum in Dottingen.",
		cover: "45.jpeg",
		gallery: [],
	},
	{
		slug: "werkstattdome",
		title: "Werkstattdome",
		year: "2024",
		context: "Workshop mit der offenen Werkstatt FREILab Freiburg e.V.",
		cover: "43.jpeg",
		gallery: ["44.jpeg"],
	},
	{
		slug: "gaertnerinnendome",
		title: "Gärtner*Innendome",
		year: "2024",
		context: "Mit dem Verein Weltacker e.V., Freiburg.",
		cover: "39.jpeg",
		gallery: ["40.jpeg", "41.jpeg", "42.jpeg"],
	},
	{
		slug: "international-domes",
		title: "International Domes",
		year: "2024",
		context: "Auf dem internationalen Kunst- und Kulturfestival, Freiburg.",
		cover: "37.jpeg",
		gallery: ["38.jpeg"],
	},
	{
		slug: "bergfritzendome",
		title: "Bergfritzendome",
		year: "2023",
		context: "Workshop mit dem Wohnprojekt Bergfritzenhof im Schwarzwald.",
		cover: "33.jpeg",
		gallery: ["34.jpeg", "35.jpeg", "36.jpeg"],
	},
	{
		slug: "oasendome",
		title: "Oasendome",
		year: "2023",
		context: "Wohngenossenschaft Genova, Freiburg.",
		cover: "29.jpg",
		gallery: ["30.jpg", "31.jpg", "32.jpg"],
	},
	{
		slug: "nord-sued-dome",
		title: "Nord-Süd-Dome",
		year: "2022",
		context: "Auf der Landesgartenschau als Veranstaltungsort, mit dem Süd-Nord-Forum Freiburg e.V. in Neuenburg am Rhein.",
		cover: "27a.png",
		gallery: ["27.png", "28.png"],
	},
	{
		slug: "brueckenbauerinnendome",
		title: "Brückenbauer*Innendome",
		year: "2022",
		context: "Workshop im Haus des Engagements, Freiburg.",
		cover: "21.jpg",
		gallery: ["22.jpg", "23.jpg", "24.jpg", "25.jpg", "26.jpg"],
	},
	{
		slug: "bambusdome",
		title: "Bambusdome am See",
		year: "2022",
		context: "Familienprojekt.",
		cover: "19.jpg",
		gallery: ["20.jpg"],
	},
	{
		slug: "kinderdome",
		title: "Kinderdome",
		year: "2021",
		context: "Beim Kinderkunstdorf, Freiburg.",
		cover: "11.jpg",
		gallery: ["12.jpg", "13.jpg", "14.jpg", "15.jpg", "16.jpg"],
	},
	{
		slug: "rettungsdome",
		title: "Rettungsdome",
		year: "2021",
		context: "Webinar beim Foodsharing-Festival.",
		cover: "4.jpg",
		gallery: [],
	},
	{
		slug: "orientdome",
		title: "Orientdome",
		year: "2021",
		context: "Familienprojekt im Odenwald.",
		cover: "3.jpg",
		gallery: [],
	},
	{
		slug: "andendome",
		title: "Andendome",
		year: "2021",
		context: "Familienprojekt im Odenwald.",
		cover: "1.jpg",
		gallery: ["2.jpg"],
	},
];

const imgPath = (file: string) => `${root}/images/projekte/${file}`;
---
<VariantB title="Abgeschlossene Projekte — GardenGeoDome" activeNav="projekte">
	<header class="page-header">
		<div class="kicker">Projekte</div>
		<h1>Was bisher <strong>entstand.</strong></h1>
		<p class="lede">Eine Auswahl gebauter Geodome — für Festivals, Schulen, Gärten, Begegnungsorte. Jeder Ort und jede Gruppe schreibt die Form anders. Klick einen Eintrag an, um mehr Fotos zu sehen.</p>
	</header>

	<section class="pj-timeline">
		{projekte.map((p) => (
			<article class="pj-item" data-slug={p.slug}>
				<button type="button" class="pj-cover" aria-expanded="false" aria-controls={`pj-panel-${p.slug}`}>
					<img src={imgPath(p.cover)} alt={p.title} loading="lazy" />
					<div class="pj-overlay">
						<div class="pj-overlay-inner">
							<span class="pj-year">{p.year}</span>
							<h2 class="pj-title">{p.title}</h2>
							<p class="pj-context">{p.context}</p>
						</div>
						<span class="pj-toggle" aria-hidden="true">
							<span class="pj-toggle-icon"></span>
						</span>
					</div>
				</button>
				<div class="pj-panel" id={`pj-panel-${p.slug}`} role="region" aria-label={`Weitere Fotos: ${p.title}`}>
					<div class="pj-panel-inner">
						{p.gallery.length > 0 ? (
							<div class="pj-gallery">
								{p.gallery.map((g) => (
									<figure class="pj-thumb">
										<img src={imgPath(g)} alt={`${p.title} — weitere Ansicht`} loading="lazy" />
									</figure>
								))}
							</div>
						) : (
							<p class="pj-no-more">Nur ein Foto zu diesem Projekt.</p>
						)}
					</div>
				</div>
			</article>
		))}
	</section>

	<section class="pj-cta">
		<h2>Dein Projekt als nächstes?</h2>
		<p>Wir sprechen über Ort, Gruppe, Anlass — und finden eine Geodome-Form, die für dich passt.</p>
		<a class="btn primary" href={`${root}/buchung?type=frage`}>Projekt anfragen</a>
	</section>

	<script is:inline>
		(function () {
			const items = document.querySelectorAll(".pj-item");
			items.forEach((item) => {
				const btn = item.querySelector(".pj-cover");
				const panel = item.querySelector(".pj-panel");
				if (!btn || !panel) return;
				btn.addEventListener("click", () => {
					const isOpen = item.classList.toggle("is-open");
					btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
				});
			});
		})();
	</script>

	<style>
		.pj-timeline {
			padding: 2rem 3rem 5rem;
			border-top: 1px solid var(--line);
			display: flex;
			flex-direction: column;
			gap: 1.5rem;
			max-width: 1200px;
			margin: 0 auto;
		}

		.pj-item {
			background: var(--surface);
			border: 1px solid var(--line);
			overflow: hidden;
		}

		.pj-cover {
			display: block;
			position: relative;
			width: 100%;
			padding: 0;
			border: none;
			background: var(--bg);
			cursor: pointer;
			font: inherit;
			color: inherit;
			text-align: left;
			overflow: hidden;
		}
		.pj-cover img {
			display: block;
			width: 100%;
			aspect-ratio: 16 / 7;
			object-fit: cover;
			transition: transform 500ms ease;
		}
		.pj-cover:hover img,
		.pj-cover:focus-visible img { transform: scale(1.03); }
		.pj-cover:focus-visible { outline: 2px solid var(--green-deep); outline-offset: -2px; }

		.pj-overlay {
			position: absolute;
			inset: 0;
			display: flex;
			align-items: flex-end;
			justify-content: space-between;
			gap: 1.5rem;
			padding: 1.75rem 2rem;
			background: linear-gradient(180deg, rgba(26,26,26,0) 35%, rgba(26,26,26,0.78) 100%);
			color: var(--bg);
			pointer-events: none;
		}
		.pj-overlay-inner { max-width: 60ch; }
		.pj-year {
			display: inline-block;
			font-size: 0.78rem;
			letter-spacing: 0.18em;
			font-weight: 700;
			margin-bottom: 0.4rem;
			opacity: 0.9;
		}
		.pj-title {
			font-family: "Fraunces Variable", "Fraunces", Georgia, serif;
			font-variation-settings: "SOFT" 80, "WONK" 1, "opsz" 144;
			font-size: clamp(1.5rem, 3vw, 2.25rem);
			font-weight: 500;
			line-height: 1.1;
			letter-spacing: -0.01em;
			margin: 0 0 0.4rem;
		}
		.pj-context {
			margin: 0;
			font-size: 0.95rem;
			line-height: 1.45;
			opacity: 0.92;
			max-width: 56ch;
		}

		.pj-toggle {
			flex-shrink: 0;
			width: 2.5rem;
			height: 2.5rem;
			border-radius: 50%;
			background: rgba(255,255,255,0.12);
			border: 1px solid rgba(255,255,255,0.35);
			display: flex;
			align-items: center;
			justify-content: center;
			transition: background 200ms, transform 250ms;
		}
		.pj-cover:hover .pj-toggle { background: rgba(255,255,255,0.22); }
		.pj-toggle-icon {
			width: 10px;
			height: 10px;
			border-right: 2px solid var(--bg);
			border-bottom: 2px solid var(--bg);
			transform: rotate(45deg);
			transition: transform 250ms;
			margin-top: -3px;
		}
		.pj-item.is-open .pj-toggle-icon { transform: rotate(-135deg); margin-top: 3px; }

		.pj-panel {
			display: grid;
			grid-template-rows: 0fr;
			transition: grid-template-rows 350ms ease;
			background: var(--surface);
		}
		.pj-panel-inner {
			overflow: hidden;
			min-height: 0;
		}
		.pj-item.is-open .pj-panel {
			grid-template-rows: 1fr;
		}

		.pj-gallery {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
			gap: 0.75rem;
			padding: 1.25rem 1.5rem 1.5rem;
		}
		.pj-thumb {
			margin: 0;
			background: var(--bg);
			aspect-ratio: 4 / 3;
			overflow: hidden;
		}
		.pj-thumb img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
			transition: transform 400ms ease;
		}
		.pj-thumb:hover img { transform: scale(1.05); }

		.pj-no-more {
			padding: 1.25rem 1.5rem 1.5rem;
			margin: 0;
			color: var(--muted);
			font-size: 0.9rem;
			font-style: italic;
		}

		.pj-cta {
			padding: 5rem 3rem;
			text-align: center;
			background: var(--surface);
			border-top: 1px solid var(--line);
			border-bottom: 1px solid var(--line);
		}
		.pj-cta h2 {
			font-size: clamp(1.75rem, 3.5vw, 2.5rem);
			font-weight: 300;
			margin-bottom: 1rem;
		}
		.pj-cta p {
			color: var(--muted);
			margin-bottom: 2rem;
			max-width: 32em;
			margin-left: auto;
			margin-right: auto;
		}

		@media (max-width: 760px) {
			.pj-timeline { padding: 1.5rem 1rem 3rem; gap: 1rem; }
			.pj-cover img { aspect-ratio: 4 / 3; }
			.pj-overlay { padding: 1.25rem 1.25rem; }
			.pj-title { font-size: 1.5rem; }
			.pj-context { font-size: 0.88rem; }
			.pj-gallery { grid-template-columns: repeat(2, 1fr); gap: 0.5rem; padding: 1rem; }
			.pj-toggle { width: 2.2rem; height: 2.2rem; }
			.pj-cta { padding: 3rem 1.5rem; }
		}
	</style>
</VariantB>
