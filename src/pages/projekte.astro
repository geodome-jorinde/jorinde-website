		year: "2023",
		context: "Workshop mit dem Wohnprojekt Bergfritzenhof im Schwarzwald.",
		cover: "33.webp",
		gallery: ["34.webp", "35.webp", "36.webp"],
	},
	{
		slug: "oasendome",
		title: "Oasendome",
		year: "2023",
		context: "Wohngenossenschaft Genova, Freiburg.",
		cover: "29.webp",
		gallery: ["30.webp", "31.webp", "32.webp"],
	},
	{
		slug: "piratendome",
		title: "Piratendome",
		year: "2022",
		context: "Pfingstcamp mit den Stadtpiraten Freiburg e.V., Freiburg.",
		cover: "29a.webp",
		gallery: ["29b.webp", "29c.webp", "29d.webp"],
	},
	{
		slug: "nord-sued-dome",
