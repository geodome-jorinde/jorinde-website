---
import VariantB from "../layouts/VariantB.astro";
const root = import.meta.env.BASE_URL.replace(/\/$/, "");

const projekte = [
	{ src: `${root}/images/preview/projekt-1.jpg`, title: "Sommerfest", year: "2024" },
	{ src: `${root}/images/preview/projekt-2.jpg`, title: "Festival-Lounge", year: "2024" },
	{ src: `${root}/images/preview/projekt-3.jpg`, title: "Schul-Workshop", year: "2023" },
	{ src: `${root}/images/preview/projekt-4.jpg`, title: "Garten-Pavillon", year: "2023" },
	{ src: `${root}/images/preview/projekt-5.jpg`, title: "Kulturveranstaltung", year: "2023" },
	{ src: `${root}/images/preview/projekt-6.jpg`, title: "Privatgarten", year: "2022" },
	{ src: `${root}/images/preview/projekt-7.jpg`, title: "Open-Air", year: "2022" },
	{ src: `${root}/images/preview/projekt-8.jpg`, title: "Workshop-Tag", year: "2022" },
];
---
<VariantB title="Abgeschlossene Projekte — GardenGeoDome" activeNav="projekte">
	<header class="page-header">
		<div class="kicker">Projekte</div>
		<h1>Was bisher <strong>entstand.</strong></h1>
		<p class="lede">Eine Auswahl gebauter Geodome — für Festivals, Schulen, Gärten, Begegnungsorte. Jeder Ort und jede Gruppe schreibt die Form anders.</p>
	</header>

	<section class="pj-grid">
		{projekte.map((p, i) => (
			<figure class={`pj-card pj-${(i % 5) + 1}`}>
				<img src={p.src} alt={p.title} loading="lazy" />
				<figcaption>
					<span class="pj-title">{p.title}</span>
					<span class="pj-year">{p.year}</span>
				</figcaption>
			</figure>
		))}
	</section>

	<section class="pj-cta">
		<h2>Dein Projekt als nächstes?</h2>
		<p>Wir sprechen über Ort, Gruppe, Anlass — und finden eine Geodome-Form, die für dich passt.</p>
		<a class="btn primary" href={`${root}/buchung?type=frage`}>Projekt anfragen</a>
	</section>

	<style>
		.pj-grid {
			padding: 2rem 3rem 5rem;
			display: grid;
			grid-template-columns: repeat(12, 1fr);
			grid-auto-rows: minmax(180px, auto);
			gap: 1.25rem;
			border-top: 1px solid var(--line);
			padding-top: 3rem;
		}
		.pj-card { position: relative; overflow: hidden; background: var(--surface); }
		.pj-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms; }
		.pj-card:hover img { transform: scale(1.04); }
		.pj-card figcaption {
			position: absolute; left: 0; right: 0; bottom: 0;
			padding: 0.85rem 1rem;
			background: linear-gradient(180deg, rgba(26,26,26,0) 0%, rgba(26,26,26,0.78) 100%);
			color: var(--bg);
			display: flex; justify-content: space-between; align-items: center;
			font-size: 0.85rem;
			opacity: 0; transform: translateY(8px); transition: opacity 200ms, transform 200ms;
		}
		.pj-card:hover figcaption { opacity: 1; transform: translateY(0); }
		.pj-title { font-weight: 600; }
		.pj-year { letter-spacing: 0.1em; opacity: 0.85; }

		.pj-card:nth-child(1) { grid-column: span 7; grid-row: span 2; }
		.pj-card:nth-child(2) { grid-column: span 5; grid-row: span 1; }
		.pj-card:nth-child(3) { grid-column: span 5; grid-row: span 1; }
		.pj-card:nth-child(4) { grid-column: span 4; grid-row: span 2; }
		.pj-card:nth-child(5) { grid-column: span 4; grid-row: span 1; }
		.pj-card:nth-child(6) { grid-column: span 4; grid-row: span 1; }
		.pj-card:nth-child(7) { grid-column: span 8; grid-row: span 2; }
		.pj-card:nth-child(8) { grid-column: span 4; grid-row: span 1; }

		.pj-cta { padding: 5rem 3rem; text-align: center; background: var(--surface); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
		.pj-cta h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 300; margin-bottom: 1rem; }
		.pj-cta p { color: var(--muted); margin-bottom: 2rem; max-width: 32em; margin-left: auto; margin-right: auto; }

		@media (max-width: 900px) {
			.pj-grid { padding: 2rem 1.5rem; grid-template-columns: 1fr; grid-auto-rows: 240px; }
			.pj-card:nth-child(n) { grid-column: span 1; grid-row: span 1; }
			.pj-card figcaption { opacity: 1; transform: none; }
			.pj-cta { padding: 3rem 1.5rem; }
		}
	</style>
</VariantB>
