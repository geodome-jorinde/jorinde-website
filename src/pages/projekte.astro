const imgPath = (file: string) => `${root}/images/projekte/${file}`;
---
<VariantB title="Abgeschlossene Projekte — Geodome Freiburg" activeNav="projekte">
	<header class="page-header">
		<div class="kicker">Projekte</div>
		<h1>Was bisher <strong>entstand.</strong></h1>
		<p class="lede">Eine Auswahl gebauter Geodome — für Festivals, Schulen, Gärten, Begegnungsorte. Jeder Ort und jede Gruppe schreibt die Form anders. Klick einen Eintrag an, um mehr Fotos zu sehen.</p>
	</header>

	<section class="pj-timeline">
		{projekte.map((p) => (
			<article class="pj-item" data-slug={p.slug}>
				<button type="button" class="pj-cover" aria-expanded="false" aria-controls={`pj-panel-${p.slug}`}>
					<img src={imgPath(p.cover)} alt={p.title} loading="lazy" decoding="async" />
					<div class="pj-overlay">
						<div class="pj-overlay-inner">
							<span class="pj-year">{p.year}</span>
							<h2 class="pj-title">{p.title}</h2>
							<p class="pj-context">{p.context}</p>
						</div>
						<span class="pj-toggle" aria-hidden="true">
							<span class="pj-toggle-icon"></span>
						</span>
					</div>
				</button>
				<div class="pj-panel" id={`pj-panel-${p.slug}`} role="region" aria-label={`Weitere Fotos: ${p.title}`}>
					<div class="pj-panel-inner">
						{p.gallery.length > 0 ? (
							<div class="pj-gallery">
								{p.gallery.map((g) => (
									<figure class="pj-thumb">
										<img src={imgPath(g)} alt={`${p.title} — weitere Ansicht`} loading="lazy" decoding="async" />
									</figure>
								))}
							</div>
						) : (
							<p class="pj-no-more">Nur ein Foto zu diesem Projekt.</p>
						)}
					</div>
				</div>
			</article>
		))}
	</section>

	<section class="pj-cta">
		<h2>Dein Projekt als nächstes?</h2>
		<p>Wir sprechen über Ort, Gruppe, Anlass — und finden eine Geodome-Form, die für dich passt.</p>
		<a class="btn primary" href={`${root}/buchung?type=frage`}>Projekt anfragen</a>
	</section>

	<script is:inline>
		(function () {
			const items = document.querySelectorAll(".pj-item");
			items.forEach((item) => {
				const btn = item.querySelector(".pj-cover");
				const panel = item.querySelector(".pj-panel");
				if (!btn || !panel) return;
				btn.addEventListener("click", () => {
					const isOpen = item.classList.toggle("is-open");
					btn.setAttribute("aria-expanded", isOpen ? "true" : "false");
				});
			});
		})();
	</script>

	<style>
		.pj-timeline {
			padding: 2rem 3rem 5rem;
			border-top: 1px solid var(--line);
			display: flex;
			flex-direction: column;
			gap: 1.5rem;
			max-width: 1200px;
			margin: 0 auto;
		}

		.pj-item {
			background: var(--surface);
			border-radius: 12px;
			overflow: hidden;
		}

		.pj-cover {
			display: block;
			position: relative;
			width: 100%;
			padding: 0;
			border: none;
			background: var(--bg);
			cursor: pointer;
			font: inherit;
			color: inherit;
			text-align: left;
			overflow: hidden;
		}
		.pj-cover img {
			display: block;
			width: 100%;
			aspect-ratio: 21 / 8;
			max-height: 360px;
			object-fit: cover;
			transition: transform 500ms ease;
		}
		.pj-cover:hover img,
		.pj-cover:focus-visible img { transform: scale(1.03); }
		.pj-cover:focus-visible { outline: 2px solid var(--green-deep); outline-offset: -2px; }

		.pj-overlay {
			position: absolute;
			inset: 0;
			display: flex;
			align-items: flex-end;
			justify-content: space-between;
			gap: 1.5rem;
			padding: 1.5rem 1.75rem;
			background: linear-gradient(180deg, rgba(26,26,26,0) 30%, rgba(26,26,26,0.82) 100%);
			color: #fff;
			pointer-events: none;
		}
		.pj-overlay-inner { max-width: 60ch; color: #fff; }
		.pj-year {
			display: inline-block;
			font-size: 0.78rem;
			letter-spacing: 0.18em;
			font-weight: 700;
			margin-bottom: 0.4rem;
			color: #fff;
		}
		.pj-title {
			font-size: clamp(1.4rem, 2.6vw, 1.9rem);
			font-weight: 700;
			line-height: 1.15;
			letter-spacing: -0.01em;
			margin: 0 0 0.4rem;
			color: #fff;
		}
		.pj-context {
			margin: 0;
			font-size: 0.95rem;
			line-height: 1.45;
			color: #fff;
			max-width: 56ch;
		}

		.pj-toggle {
			flex-shrink: 0;
			width: 2.5rem;
			height: 2.5rem;
			border-radius: 50%;
			background: rgba(255,255,255,0.12);
			border: 1px solid rgba(255,255,255,0.35);
			display: flex;
			align-items: center;
			justify-content: center;
			transition: background 200ms, transform 250ms;
		}
		.pj-cover:hover .pj-toggle { background: rgba(255,255,255,0.22); }
		.pj-toggle-icon {
			width: 10px;
			height: 10px;
			border-right: 2px solid var(--bg);
			border-bottom: 2px solid var(--bg);
			transform: rotate(45deg);
			transition: transform 250ms;
			margin-top: -3px;
		}
		.pj-item.is-open .pj-toggle-icon { transform: rotate(-135deg); margin-top: 3px; }

		.pj-panel {
			display: grid;
			grid-template-rows: 0fr;
			transition: grid-template-rows 350ms ease;
			background: var(--surface);
		}
		.pj-panel-inner {
			overflow: hidden;
			min-height: 0;
		}
		.pj-item.is-open .pj-panel {
			grid-template-rows: 1fr;
		}

		.pj-gallery {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(384px, 1fr));
			gap: 1rem;
			padding: 1.5rem;
		}
		.pj-thumb {
			margin: 0;
			background: var(--bg);
			aspect-ratio: 4 / 3;
			overflow: hidden;
			border-radius: 8px;
		}
		.pj-thumb img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
			transition: transform 400ms ease;
		}
		.pj-thumb:hover img { transform: scale(1.05); }

		.pj-no-more {
			padding: 1.25rem 1.5rem 1.5rem;
			margin: 0;
			color: var(--muted);
			font-size: 0.9rem;
			font-style: italic;
		}

		.pj-cta {
			padding: 5rem 3rem;
			text-align: center;
			background: var(--surface);
			border-top: 1px solid var(--line);
			border-bottom: 1px solid var(--line);
		}
		.pj-cta h2 {
			font-size: clamp(1.75rem, 3.5vw, 2.5rem);
			font-weight: 300;
			margin-bottom: 1rem;
		}
		.pj-cta p {
			color: var(--muted);
			margin-bottom: 2rem;
			max-width: 32em;
			margin-left: auto;
			margin-right: auto;
		}

		@media (max-width: 760px) {
			.pj-timeline { padding: 1.5rem 1rem 3rem; gap: 1rem; }
			.pj-cover img { aspect-ratio: 16 / 10; max-height: none; }
			.pj-overlay { padding: 1.1rem 1.2rem; }
			.pj-title { font-size: 1.35rem; }
			.pj-context { font-size: 0.88rem; }
			.pj-gallery { grid-template-columns: 1fr; gap: 0.75rem; padding: 1rem; }
			.pj-toggle { width: 2.2rem; height: 2.2rem; }
			.pj-cta { padding: 3rem 1.5rem; }
		}
	</style>
</VariantB>
