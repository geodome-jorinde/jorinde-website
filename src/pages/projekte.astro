		title: "Brückenbauer*Innendome",
		year: "2022",
		context: "Workshop im Haus des Engagements, Freiburg.",
		cover: "21.webp",
		gallery: ["22.webp", "23.webp", "24.webp", "25.webp", "26.webp"],
	},
	{
		slug: "bambusdome",
		title: "Bambusdome am See",
		year: "2022",
		context: "Familienprojekt.",
		cover: "19.webp",
		gallery: ["20.webp"],
	},
	{
		slug: "kinderdome",
		title: "Kinderdome",
		year: "2021",
		context: "Beim Kinderkunstdorf, Freiburg.",
		cover: "11.webp",
		gallery: ["12.webp", "13.webp", "14.webp", "15.webp", "16.webp"],
