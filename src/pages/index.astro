---
import VariantB from "../layouts/VariantB.astro";
import BrandSeal from "../components/BrandSeal.astro";
const root = import.meta.env.BASE_URL.replace(/\/$/, "");

const workshops = [
	{
		num: "01",
		title: "Konstruktion erleben",
		text: "Aus einzelnen Streben entsteht Schritt für Schritt eine stabile Konstruktion — du sammelst praktische Erfahrungen mit Material, Statik und handwerklichem Können.",
		img: `${root}/images/preview/konstruktion-1.jpg`,
		href: `${root}/konstruktion-erleben`,
	},
	{
		num: "02",
		title: "Statik & Raumwirkung",
		text: "Aus Leisten, Schrauben und Winkeln entsteht ein selber gebauter Raum. Die Dreiecksstruktur verteilt Kräfte gleichmäßig — Stabilität bei minimalem Materialeinsatz.",
		img: `${root}/images/preview/statik-1.jpg`,
		href: `${root}/statik`,
	},
	{
		num: "03",
		title: "Anwendungsbereiche",
		text: "Begegnungsort, Rückzug im Garten, Gewächshaus, experimentelle Wohnform. Ein Geodome passt sich deinen Ideen an — er ist das, was du daraus machst.",
		img: `${root}/images/preview/anwendung-1.jpg`,
		href: `${root}/anwendungsbereiche`,
	},
];
---
<VariantB title="GardenGeoDome — Geodome-Workshops in Freiburg" activeNav={null}>
	<header class="hero">
		<div class="hero-copy">
			<div class="hero-seal" style="color: var(--green-deep);">
				<BrandSeal size={150} variant="fine" font="fraunces" flora={true} />
			</div>
			<h1>Die Faszination von <strong>Geodomen erleben.</strong></h1>
			<p class="lede">Mit handwerklicher Erfahrung und künstlerischem Blick lade ich ein, Geodome praktisch zu erleben. In meinen Workshops bauen wir gemeinsam und in wenigen Stunden eine stabile Kuppel — Grundlage für eure eigenen Ideen und Projekte.</p>
			<div class="cta-row">
				<a class="btn primary" href="#workshops">Workshops ansehen</a>
				<a class="btn" href={`${root}/zu-mir`}>Über Jorinde</a>
			</div>
		</div>
		<div class="hero-visual">
			<img src={`${root}/images/preview/hero-klettern.jpg`} alt="Kinder im fertigen Geodome unter Baumkronen" />
			<div class="ticks"></div>
		</div>
	</header>

	<section class="workshops" id="workshops">
		<div class="section-head">
			<h2>Was im Workshop entsteht.</h2>
			<div class="meta">
				<span><strong>Material</strong> Holz · Schrauben · Winkel</span>
				<span><strong>Dauer</strong> 4–8 Stunden</span>
				<span><strong>Ort</strong> Freiburg & on-site</span>
			</div>
		</div>
		<div class="workshop-grid">
			{workshops.map((w) => (
				<a class="workshop" href={w.href}>
					<div class="workshop-num">{w.num}<span class="tri"></span></div>
					<img src={w.img} alt={w.title} />
					<h3>{w.title}</h3>
					<p>{w.text}</p>
					<span class="more">Mehr →</span>
				</a>
			))}
		</div>
	</section>

	<section class="principle" id="prinzip">
		<div class="principle-img">
			<img src={`${root}/images/preview/principle-dome-lake.jpg`} alt="Geodome am See — Triangulation als Rahmen, Blick auf Wasser und Himmel" />
		</div>
		<div>
			<div class="kicker">Prinzip</div>
			<h2>Geborgenheit und <strong>Weite zugleich.</strong></h2>
			<p>Die besondere Dreiecksstruktur verteilt Kräfte gleichmäßig über die gesamte Oberfläche — ein Prinzip, das Geodome große Stabilität bei geringem Materialeinsatz verleiht.</p>
			<p>Die ruhige, lichtdurchflutete und zugleich abgeschirmte Atmosphäre schafft gute Bedingungen für Erholung und sorgt für ein Gefühl von Geborgenheit und Weite zugleich.</p>
		</div>
	</section>

	<style>
		.hero {
			display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;
			padding: 4rem 3rem 6rem;
			border-bottom: 1px solid var(--line);
			align-items: center;
		}
		.hero-seal { margin-bottom: 1.75rem; }
		.hero h1 {
			font-size: clamp(2.5rem, 5.5vw, 4.5rem);
			font-weight: 300; letter-spacing: -0.035em;
			line-height: 1.02; margin-bottom: 1.5rem;
		}
		.hero .lede {
			font-size: 1.1rem; font-weight: 400; color: var(--muted);
			max-width: 32em; margin-bottom: 2rem;
		}
		.cta-row { display: flex; gap: 1rem; flex-wrap: wrap; }

		.hero-visual { position: relative; aspect-ratio: 4 / 5; overflow: hidden; background: var(--bg); }
		.hero-visual img { width: 100%; height: 100%; object-fit: cover; }
		.hero-visual .ticks { position: absolute; inset: 0; pointer-events: none; }
		.hero-visual .ticks::before, .hero-visual .ticks::after {
			content: ""; position: absolute;
			width: 10px; height: 10px;
			background: var(--green-deep);
			border-radius: 50%;
			box-shadow: 0 1px 4px rgba(0,0,0,0.25);
		}
		.hero-visual .ticks::before { top: 1.25rem; left: 1.25rem; }
		.hero-visual .ticks::after { bottom: 1.25rem; right: 1.25rem; }

		.workshops { padding: 6rem 3rem; border-bottom: 1px solid var(--line); }
		.section-head {
			display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;
			margin-bottom: 4rem; align-items: end;
		}
		.section-head h2 {
			font-size: clamp(1.75rem, 3.5vw, 2.75rem);
			font-weight: 300;
		}
		.section-head .meta {
			font-size: 0.85rem; color: var(--muted);
			display: flex; flex-direction: column; gap: 0.25rem;
		}
		.section-head .meta strong { color: var(--ink); font-weight: 600; }

		.workshop-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
		.workshop-grid > .workshop:nth-child(2) { transform: translateY(2rem); }
		.workshop {
			border: 1px solid var(--line);
			background: var(--surface);
			padding: 1.5rem;
			display: flex; flex-direction: column; gap: 1rem;
			transition: transform 200ms, box-shadow 200ms;
			color: inherit;
		}
		.workshop:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(45,74,43,0.12); }
		.workshop-grid > .workshop:nth-child(2):hover { transform: translateY(2rem) translateY(-4px); }
		.workshop-num {
			font-size: 0.75rem; font-weight: 700; letter-spacing: 0.15em;
			color: var(--green-deep);
			display: flex; justify-content: space-between; align-items: center;
		}
		.workshop-num .tri {
			width: 12px; height: 10px;
			background: currentColor;
			clip-path: polygon(50% 0, 100% 100%, 0 100%);
		}
		.workshop img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; }
		.workshop h3 { font-size: 1.2rem; font-weight: 600; }
		.workshop p { font-size: 0.92rem; color: var(--muted); }
		.workshop .more {
			margin-top: auto; font-size: 0.85rem; font-weight: 600;
			color: var(--green-deep);
		}

		.principle {
			padding: 6rem 3rem;
			display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
		}
		.principle-img { aspect-ratio: 4 / 3; overflow: hidden; }
		.principle-img img { width: 100%; height: 100%; object-fit: cover; }
		.principle h2 {
			font-size: clamp(1.5rem, 3vw, 2.25rem);
			font-weight: 300; line-height: 1.15; margin-bottom: 1.25rem;
		}
		.principle p { color: var(--muted); max-width: 30em; margin-bottom: 1rem; font-size: 1rem; }

		@media (max-width: 900px) {
			.hero, .principle { grid-template-columns: 1fr; padding: 3rem 1.5rem; gap: 2rem; }
			.workshops { padding: 3rem 1.5rem; }
			.section-head { grid-template-columns: 1fr; gap: 1.5rem; margin-bottom: 2rem; }
			.workshop-grid { grid-template-columns: 1fr; }
			.workshop-grid > .workshop:nth-child(n) { transform: none; }
			.workshop-grid > .workshop:nth-child(2):hover { transform: translateY(-4px); }
		}
	</style>
</VariantB>
