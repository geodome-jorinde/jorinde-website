---
import VariantB from "../layouts/VariantB.astro";
const root = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<VariantB title="Workshop buchen oder fragen — GardenGeoDome" activeNav="buchung">
	<header class="page-header">
		<div class="kicker">Buchen · Fragen</div>
		<h1>Workshop buchen<br /><strong>— oder einfach fragen.</strong></h1>
		<p class="lede">Wähle einen Workshop und schlage einen Termin vor — oder stell einfach eine Frage. Ich melde mich innerhalb weniger Tage zurück; verbindlich wird es erst nach unserer Rücksprache.</p>
	</header>

	<form id="buchung-form" class="bk-form">
		<!-- Step 1: Workshop -->
		<section class="bk-step">
			<div class="bk-step-head">
				<span class="bk-step-num">01</span>
				<h2>Welcher Workshop?</h2>
			</div>
			<p class="bk-options-tip"><strong>Tipp:</strong> Je mehr Teilnehmer:innen, desto stimmiger das Erlebnis — Geodome-Bauen lebt von vielen Händen und Kooperation.</p>
			<div class="bk-options">
				<label class="bk-option">
					<input type="radio" name="workshop" value="3-Stunden-Workshop (140 EUR)" checked />
					<div class="bk-opt-card">
						<div class="bk-opt-tag">3-Stunden-Workshop</div>
						<div class="bk-opt-price"><strong>140 €</strong><span>zzgl. Anreise außerhalb Freiburgs (&gt;30 km)</span></div>
						<p class="bk-opt-lead">Ein praxisnaher Einstieg in den Geodome-Bau — verständlich, kreativ, gemeinschaftlich.</p>
						<ul>
							<li>Dauer: ca. 3 Stunden</li>
							<li>Gruppengröße: flexibel</li>
							<li>Material inklusive</li>
							<li>Für Schul- und Projektgruppen, als Team-Event, auch für Einzelpersonen</li>
						</ul>
					</div>
				</label>

				<label class="bk-option">
					<input type="radio" name="workshop" value="Ganztaegiger Workshop (480 EUR)" />
					<div class="bk-opt-card">
						<div class="bk-opt-tag">Ganztägiger Workshop</div>
						<div class="bk-opt-price"><strong>480 €</strong><span>zzgl. Material</span></div>
						<p class="bk-opt-lead">Gemeinschaftlich. Kreativ. Nachhaltig.</p>
						<ul>
							<li>Dauer: ca. 6–8 Stunden</li>
							<li>Gruppengröße: flexibel</li>
							<li>Material: <em>recycelt</em> oder <em>neu</em></li>
							<li>Fertiger Geodome zum Mitnehmen</li>
							<li>Verbindet gemeinschaftliches Gestalten mit handwerklicher Erfahrung und spielerischer Strukturfindung.</li>
						</ul>
					</div>
				</label>

				<label class="bk-option bk-option-custom">
					<input type="radio" name="workshop" value="Individuell angepasst (Preis auf Anfrage)" />
					<div class="bk-opt-card">
						<div class="bk-opt-tag">Individuell angepasst</div>
						<div class="bk-opt-price"><strong>auf Anfrage</strong><span>Preis nach Format &amp; Material</span></div>
						<p class="bk-opt-lead">Für pädagogische Einrichtungen, Vereine, Unternehmen, Festivals und weitere Gemeinschaftsprojekte. Vom ersten Entwurf bis zur fertigen Kuppel — ein Projekt, das verbindet.</p>
						<ul>
							<li>Vom kompakten Workshop bis hin zu Tagesformaten oder Projektwochen</li>
							<li>Gruppengröße: flexibel</li>
							<li>Material: <em>recycelt</em> oder <em>neu</em></li>
							<li>Fertiger Geodome zum Mitnehmen</li>
							<li>Verbindet gemeinschaftliches Gestalten mit handwerklicher Erfahrung und spielerischer Strukturfindung.</li>
						</ul>
					</div>
				</label>

				<label class="bk-option bk-option-question">
					<input type="radio" name="workshop" value="Frage / Allgemeine Anfrage" />
					<div class="bk-opt-card">
						<div class="bk-opt-tag">Frage · Allgemeine Anfrage</div>
						<p class="bk-opt-lead">Du bist noch nicht bereit zu buchen? Stell einfach eine Frage — zu Workshops, Projekten, Materialien, Kooperationen oder allem anderen. Datum und Gruppengröße kannst du dann überspringen.</p>
					</div>
				</label>
			</div>
		</section>

		<!-- Step 2: Datum (booking-only) -->
		<section class="bk-step bk-step-booking">
			<div class="bk-step-head">
				<span class="bk-step-num">02</span>
				<h2>Wunsch-Termin.</h2>
			</div>
			<p class="bk-step-hint">Bitte plane 4–6 Wochen Vorlauf ein. Alternative Termine kannst du im Freitext-Feld nennen.</p>
			<div class="bk-grid-2">
				<div class="bk-field">
					<label for="datum">Datum</label>
					<input type="date" id="datum" name="datum" required />
				</div>
				<div class="bk-field">
					<label for="alternativ">Alternative (optional)</label>
					<input type="text" id="alternativ" name="alternativ" placeholder="z.B. eine Woche später, Wochenende danach" />
				</div>
			</div>
		</section>

		<!-- Step 3: Gruppe & Ort (booking-only) -->
		<section class="bk-step bk-step-booking">
			<div class="bk-step-head">
				<span class="bk-step-num">03</span>
				<h2>Gruppe & Ort.</h2>
			</div>
			<div class="bk-grid-2">
				<div class="bk-field">
					<label for="personen">Anzahl Personen</label>
					<input type="number" id="personen" name="personen" min="1" max="20" placeholder="z.B. 6" required />
				</div>
				<div class="bk-field">
					<label for="ort">Ort / PLZ</label>
					<input type="text" id="ort" name="ort" placeholder="z.B. Freiburg, 79100 — oder bei mir in Freiburg" required />
				</div>
			</div>
		</section>

		<!-- Step 4: Kontakt -->
		<section class="bk-step">
			<div class="bk-step-head">
				<span class="bk-step-num">04</span>
				<h2>Deine Kontaktdaten.</h2>
			</div>
			<div class="bk-grid-2">
				<div class="bk-field">
					<label for="name">Name</label>
					<input type="text" id="name" name="name" required autocomplete="name" />
				</div>
				<div class="bk-field">
					<label for="email">E-Mail</label>
					<input type="email" id="email" name="email" required autocomplete="email" />
				</div>
			</div>
			<div class="bk-field">
				<label for="telefon">Telefon (optional)</label>
				<input type="tel" id="telefon" name="telefon" autocomplete="tel" />
			</div>
		</section>

		<!-- Step 5: Nachricht -->
		<section class="bk-step">
			<div class="bk-step-head">
				<span class="bk-step-num">05</span>
				<h2>Hintergrund &amp; Wünsche.</h2>
			</div>
			<div class="bk-field">
				<label for="msg">Nachricht (optional)</label>
				<textarea id="msg" name="msg" rows="6" placeholder="Anlass, Material-Vorliebe (für Ganztags-Workshop), besondere Wünsche, Fragen — alles was hilft, deinen Workshop zu planen."></textarea>
			</div>
		</section>

		<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" class="bk-hp" />

		<div class="bk-consent-block">
			<label class="bk-consent bk-newsletter-opt">
				<input type="checkbox" name="newsletter" />
				<span>Ja, ich möchte gelegentlich Updates zu Workshop-Terminen und Projekten erhalten (Newsletter, Abmelden jederzeit per E-Mail).</span>
			</label>
			<label class="bk-consent">
				<input type="checkbox" name="consent" required />
				<span>Ich willige ein, dass meine angegebenen Daten (Name, E-Mail, Telefon, Anfrage-Details) zur Bearbeitung meiner Anfrage verarbeitet werden. Die Daten werden nicht an Dritte weitergegeben und spätestens 6 Monate nach Abschluss der Anfrage gelöscht. Ich kann meine Einwilligung jederzeit per E-Mail an <a href="mailto:info@gardengeodome.com">info@gardengeodome.com</a> widerrufen. Mehr in der <a href={`${root}/datenschutz`}>Datenschutzerklärung</a>.</span>
			</label>
		</div>

		<div class="bk-submit">
			<button type="submit" class="btn primary bk-submit-btn">Anfrage absenden</button>
			<p class="bk-form-hint">Öffnet dein E-Mail-Programm. Es ist eine <em>Anfrage</em> — die Buchung wird erst nach unserer Rücksprache verbindlich. Falls du keinen E-Mail-Client hast, schreib direkt an <a href="mailto:info@gardengeodome.com">info@gardengeodome.com</a>.</p>
		</div>
	</form>

	<script is:inline>
		// Pre-select workshop type from URL: /buchung?type=3h | ganztaegig | individuell | frage
		(function () {
			const params = new URLSearchParams(window.location.search);
			const t = params.get("type");
			const map = {
				"3h": "3-Stunden-Workshop (140 EUR)",
				"ganztaegig": "Ganztaegiger Workshop (480 EUR)",
				"individuell": "Individuell angepasst (Preis auf Anfrage)",
				"frage": "Frage / Allgemeine Anfrage",
			};
			if (t && map[t]) {
				const radio = document.querySelector('input[name="workshop"][value="' + map[t] + '"]');
				if (radio) radio.checked = true;
			}
		})();

		// Toggle booking-only sections (Datum, Gruppe & Ort) based on workshop choice.
		(function () {
			const form = document.getElementById("buchung-form");
			if (!form) return;
			const submitBtn = form.querySelector(".bk-submit-btn");
			const bookingFields = ["datum", "personen", "ort"];

			function applyMode() {
				const checked = form.querySelector('input[name="workshop"]:checked');
				const isFrage = checked && checked.value.startsWith("Frage");
				form.classList.toggle("is-question-mode", isFrage);
				bookingFields.forEach((name) => {
					const el = form[name];
					if (el) el.required = !isFrage;
				});
				if (submitBtn) submitBtn.textContent = isFrage ? "Frage senden" : "Anfrage absenden";
			}

			form.querySelectorAll('input[name="workshop"]').forEach((r) => r.addEventListener("change", applyMode));
			applyMode();
		})();

		// Submit handler — builds mailto: URL programmatically so Chrome doesn't
		// flag the form as insecure (which it does for action="mailto:...").
		(function () {
			const form = document.getElementById("buchung-form");
			if (!form) return;
			form.addEventListener("submit", function (e) {
				e.preventDefault();
				if (!form.checkValidity()) { form.reportValidity(); return; }
				if (form._gotcha && form._gotcha.value) return;
				const data = new FormData(form);
				const get = (k) => (data.get(k) || "").toString().trim();
				const isFrage = get("workshop").startsWith("Frage");
				const newsletter = data.get("newsletter") ? "ja" : "nein";

				const lines = isFrage
					? [
						"Allgemeine Anfrage von " + get("name"),
						"",
						"Anliegen:    " + get("workshop"),
						"",
						"Kontakt:",
						"  Name:    " + get("name"),
						"  E-Mail:  " + get("email"),
						"  Telefon: " + (get("telefon") || "—"),
						"",
						"Nachricht:",
						(get("msg") || "—"),
						"",
						"Newsletter: " + newsletter,
						"",
						"---",
						"Einwilligung zur Datenverarbeitung erteilt.",
					].join("\n")
					: [
						"Workshop-Buchungsanfrage von " + get("name"),
						"",
						"Workshop:    " + get("workshop"),
						"Datum:       " + get("datum"),
						"Alternative: " + (get("alternativ") || "—"),
						"Personen:    " + get("personen"),
						"Ort / PLZ:   " + get("ort"),
						"",
						"Kontakt:",
						"  Name:    " + get("name"),
						"  E-Mail:  " + get("email"),
						"  Telefon: " + (get("telefon") || "—"),
						"",
						"Nachricht:",
						(get("msg") || "—"),
						"",
						"Newsletter: " + newsletter,
						"",
						"---",
						"Einwilligung zur Datenverarbeitung erteilt.",
					].join("\n");

				const subjectPrefix = isFrage ? "Anfrage von " : "Workshop-Buchungsanfrage von ";
				const subject = encodeURIComponent(subjectPrefix + get("name"));
				const body = encodeURIComponent(lines);
				window.location.href = "mailto:info@gardengeodome.com?subject=" + subject + "&body=" + body;
			});
		})();
	</script>

	<style>
		.bk-form {
			padding: 2rem 3rem 6rem;
			max-width: 980px;
			border-top: 1px solid var(--line);
		}

		.bk-step {
			padding: 2.5rem 0 1rem;
			border-top: 1px solid rgba(26,26,26,0.1);
		}
		.bk-step:first-child { border-top: none; padding-top: 1.5rem; }
		.bk-step-head {
			display: flex; align-items: baseline; gap: 1.25rem;
			margin-bottom: 1.25rem;
		}
		.bk-step-num {
			font-family: "Fraunces Variable", "Fraunces", Georgia, serif;
			font-size: 0.85rem; font-weight: 700;
			color: var(--green-deep);
			letter-spacing: 0.18em;
			font-variation-settings: "SOFT" 80, "WONK" 1;
		}
		.bk-step-head h2 {
			font-family: "Fraunces Variable", "Fraunces", Georgia, serif;
			font-size: clamp(1.4rem, 2.4vw, 1.85rem);
			font-weight: 500;
			font-variation-settings: "SOFT" 80, "WONK" 1, "opsz" 144;
			letter-spacing: -0.005em;
		}
		.bk-step-hint {
			color: var(--muted);
			margin-bottom: 1.25rem;
			max-width: 36em;
			font-size: 0.95rem;
		}

		.bk-options-tip {
			margin: 0 0 1.5rem;
			padding: 0.85rem 1.1rem;
			border-left: 3px solid var(--green-deep);
			background: var(--surface);
			color: var(--ink);
			font-size: 0.92rem;
			line-height: 1.5;
			max-width: 60em;
		}
		.bk-options-tip strong { color: var(--green-deep); font-weight: 700; }

		/* Workshop options */
		.bk-options {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 1.25rem;
			margin-top: 0.5rem;
		}
		.bk-option-custom .bk-opt-card {
			border-style: dashed;
			background: var(--surface);
		}
		.bk-option-question {
			grid-column: 1 / -1;
			margin-top: 0.25rem;
		}
		.bk-option-question .bk-opt-card {
			border-style: dashed;
			background: transparent;
			padding: 1.25rem 1.5rem;
		}
		.bk-option-question .bk-opt-lead {
			margin-bottom: 0;
		}
		.is-question-mode .bk-step-booking {
			display: none;
		}
		.bk-newsletter-opt span {
			color: var(--ink) !important;
		}
		@media (max-width: 1100px) {
			.bk-options { grid-template-columns: 1fr 1fr; }
			.bk-option-custom { grid-column: 1 / -1; }
			.bk-option-custom .bk-opt-card { border-style: dashed; }
		}
		.bk-option {
			cursor: pointer;
			display: block;
			position: relative;
		}
		.bk-option input[type="radio"] {
			position: absolute;
			opacity: 0;
			pointer-events: none;
		}
		.bk-opt-card {
			border: 2px solid var(--line);
			padding: 1.75rem 1.5rem;
			background: var(--bg);
			transition: border-color 150ms, background 150ms, box-shadow 150ms;
			height: 100%;
		}
		.bk-option:hover .bk-opt-card { background: var(--surface); }
		.bk-option input[type="radio"]:checked ~ .bk-opt-card,
		.bk-option:has(input[type="radio"]:checked) .bk-opt-card {
			border-color: var(--green-deep);
			background: var(--surface);
			box-shadow: inset 0 0 0 1px var(--green-deep);
		}
		.bk-opt-tag {
			font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;
			color: var(--green-deep); font-weight: 700;
			margin-bottom: 0.85rem;
		}
		.bk-opt-price {
			display: flex; align-items: baseline; gap: 0.85rem;
			margin-bottom: 1rem; flex-wrap: wrap;
		}
		.bk-opt-price strong {
			font-family: "Fraunces Variable", "Fraunces", Georgia, serif;
			font-size: clamp(1.75rem, 3vw, 2.25rem);
			font-weight: 600;
			font-variation-settings: "SOFT" 80, "WONK" 1, "opsz" 144;
			letter-spacing: -0.01em;
			color: var(--ink);
		}
		.bk-opt-price span {
			font-size: 0.82rem;
			color: var(--muted);
		}
		.bk-opt-lead {
			font-size: 1rem; line-height: 1.5;
			margin-bottom: 1rem;
		}
		.bk-option ul { list-style: none; padding: 0; }
		.bk-option ul li {
			font-size: 0.92rem;
			color: var(--muted);
			line-height: 1.5;
			padding-left: 1.1rem;
			position: relative;
			margin-bottom: 0.45rem;
		}
		.bk-option ul li::before {
			content: "·";
			position: absolute;
			left: 0;
			color: var(--green-deep);
			font-weight: 700;
		}
		.bk-option ul li em { font-style: italic; color: var(--ink); }

		/* Form fields */
		.bk-grid-2 {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1.5rem;
		}
		.bk-field {
			display: flex; flex-direction: column; gap: 0.45rem;
			margin-bottom: 1rem;
		}
		.bk-field label {
			font-size: 0.72rem;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			color: var(--green-deep);
			font-weight: 700;
		}
		.bk-field input, .bk-field textarea {
			font: inherit;
			font-size: 1rem;
			background: transparent;
			border: none;
			border-bottom: 1px solid var(--line);
			padding: 0.6rem 0;
			color: var(--ink);
			outline: none;
			transition: border-color 150ms;
			resize: vertical;
		}
		.bk-field input:focus, .bk-field textarea:focus {
			border-bottom-color: var(--green-deep);
		}
		.bk-field textarea {
			border: 1px solid var(--line);
			padding: 0.85rem 1rem;
			background: var(--surface);
			min-height: 9rem;
		}

		/* Honeypot — visually hidden, accessible to bots that fill all fields */
		.bk-hp {
			position: absolute !important;
			left: -10000px !important;
			width: 1px !important;
			height: 1px !important;
			opacity: 0 !important;
			pointer-events: none;
		}

		/* Consent block */
		.bk-consent-block {
			padding: 2rem 0 0;
			border-top: 1px solid rgba(26,26,26,0.1);
			margin-top: 1.5rem;
			display: flex; flex-direction: column; gap: 1.25rem;
		}
		.bk-consent {
			display: flex; align-items: flex-start; gap: 0.75rem;
			cursor: pointer;
			max-width: 60em;
		}
		.bk-consent input[type="checkbox"] {
			margin-top: 0.3rem;
			accent-color: var(--green-deep);
			flex-shrink: 0;
			width: 1.05rem; height: 1.05rem;
		}
		.bk-consent span {
			font-size: 0.88rem; line-height: 1.55;
			color: var(--muted);
		}
		.bk-consent a { color: var(--green-deep); border-bottom: 1px solid currentColor; }

		/* Submit */
		.bk-submit {
			padding: 2rem 0 0;
		}
		.bk-submit-btn {
			font-family: inherit;
			font-size: 1rem;
			padding: 1rem 2.25rem;
		}
		.bk-form-hint {
			margin-top: 1rem;
			font-size: 0.85rem;
			color: var(--muted);
			max-width: 38em;
			line-height: 1.55;
		}
		.bk-form-hint a {
			color: var(--green-deep);
			border-bottom: 1px solid currentColor;
			padding-bottom: 1px;
		}
		.bk-form-hint em { font-style: italic; color: var(--ink); }

		@media (max-width: 760px) {
			.bk-form { padding: 1.5rem 1.5rem 4rem; }
			.bk-options, .bk-grid-2 { grid-template-columns: 1fr; }
		}
	</style>
</VariantB>
